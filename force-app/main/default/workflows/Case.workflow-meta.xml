<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <rules>
        <fullName>Case Closed_trigg follow up Tasks</fullName>
        <actions>
            <name>First</name>
            <type>Task</type>
        </actions>
        <actions>
            <name>Third_Call_Twelve_Weeks_Out_of_Hospital</name>
            <type>Task</type>
        </actions>
        <actions>
            <name>X6_Weeks_Out_of_Hospital_Second_Phone_Call</name>
            <type>Task</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Case.Case_Type__c</field>
            <operation>equals</operation>
            <value>In Hospital</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.IsClosed</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <description>Inpatient Case is closed, this workflow creates follow up tasks for Case Owner to check in on family</description>
        <failedMigrationToolVersion>246.13.1</failedMigrationToolVersion>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <tasks>
